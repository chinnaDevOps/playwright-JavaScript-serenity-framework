{
  "name": "playwright-js-serenity-framework",
  "version": "1.0.0",
  "description": "Playwright JavaScript framework with Serenity report and screenshots",
  "scripts": {
    "clean": "rimraf target playwright-report test-results",
    "test": "failsafe clean test:execute test:report",
    "test:execute": "playwright test",
    "test:report": "serenity-bdd run --source ./target/site/serenity --destination ./target/site/serenity",
    "test:smoke": "failsafe clean test:execute:smoke test:report",
    "test:execute:smoke": "playwright test --grep \"@smoke\"",
    "test:regression": "failsafe clean test:execute:regression test:report",
    "test:execute:regression": "playwright test --grep \"@regression\"",
    "test:tag": "failsafe clean test:execute:custom test:report",
    "test:execute:custom": "playwright test",
    "show:playwright": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.0",
    "@serenity-js/assertions": "^3.33.5",
    "@serenity-js/console-reporter": "^3.33.5",
    "@serenity-js/core": "^3.33.5",
    "@serenity-js/playwright": "^3.33.5",
    "@serenity-js/playwright-test": "^3.33.5",
    "@serenity-js/serenity-bdd": "^3.33.5",
    "@serenity-js/web": "^3.33.5",
    "npm-failsafe": "^1.1.0",
    "rimraf": "^5.0.0"
  },
  "dependencies": {
    "@serenity-js/local-server": "^3.42.1"
  }
}